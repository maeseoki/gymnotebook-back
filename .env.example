# Environment Configuration
NODE_ENV=development
PORT=8080

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=gymnotebook
POSTGRES_SSL=false

# JWT Configuration
JWT_SECRET=your_512_bit_base64_encoded_secret_key_here
JWT_EXPIRES_IN=86400000

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000