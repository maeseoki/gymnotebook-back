NODE_ENV=development
HOST=0.0.0.0
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gymnotebook
DB_USER=gymnotebook
DB_PASSWORD=gymnotebook

# JWT
# Use a unique secret of at least 32 characters. Do not reuse this sample value in production.
JWT_SECRET=replace-with-a-local-development-secret-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# Mobile session tokens
# TTL values are milliseconds. Use a unique pepper of at least 32 characters and do not reuse JWT_SECRET.
MOBILE_ACCESS_TOKEN_TTL=900000
MOBILE_REFRESH_TOKEN_TTL=2592000000
MOBILE_REFRESH_TOKEN_REUSE_GRACE_MS=10000
MOBILE_REFRESH_TOKEN_PEPPER=replace-with-a-local-mobile-refresh-pepper-at-least-32-chars
MOBILE_REFRESH_TOKEN_BYTES=64
MOBILE_SESSION_CLEANUP_RETENTION_MS=7776000000

# CORS
# Comma-separated allowlist. Requests without an Origin header are allowed.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=info

# Uploads
MAX_UPLOAD_SIZE=10485760

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000

# Swagger
SWAGGER_ENABLED=true

# Workout date queries
# IANA timezone used when clients omit timezone=...
DEFAULT_TIMEZONE=Europe/Madrid
