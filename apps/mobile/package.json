{
  "name": "@gymnotebook/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "pnpm run export",
    "export": "cross-env EXPO_PUBLIC_APP_ENV=test EXPO_PUBLIC_API_URL=https://example.invalid/api EXPO_HOME=/tmp/.expo EXPO_NO_TELEMETRY=1 expo export --platform web --output-dir dist",
    "expo:config": "cross-env EXPO_PUBLIC_APP_ENV=test EXPO_PUBLIC_API_URL=https://example.invalid/api EXPO_HOME=/tmp/.expo EXPO_NO_TELEMETRY=1 expo config --type public",
    "expo:doctor": "node scripts/expo-doctor.cjs",
    "expo:install-check": "cross-env EXPO_PUBLIC_APP_ENV=test EXPO_PUBLIC_API_URL=https://example.invalid/api expo install --check",
    "lint": "biome check .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm expo:config"
  },
  "dependencies": {
    "@expo-google-fonts/space-grotesk": "0.4.1",
    "@gymnotebook/contracts": "workspace:*",
    "@hookform/resolvers": "5.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "5.101.0",
    "axios": "1.17.0",
    "expo": "~56.0.11",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.6",
    "expo-image-picker": "~56.0.17",
    "expo-linking": "~56.0.14",
    "expo-network": "~56.0.5",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "nativewind": "4.2.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "7.78.0",
    "react-native": "0.85.3",
    "react-native-css-interop": "0.2.5",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "3.4.19",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@gymnotebook/typescript-config": "workspace:*",
    "@testing-library/react-native": "14.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "cross-env": "10.1.0",
    "expo-doctor": "1.19.9",
    "jest": "29.7.0",
    "jest-expo": "56.0.5",
    "react-test-renderer": "19.2.3",
    "typescript": "6.0.3"
  }
}
